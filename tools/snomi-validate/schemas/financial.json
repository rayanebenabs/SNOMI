{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://snomi.io/schema/v2/financial.json",
  "title": "SNOMI Financial v2.1",
  "description": "Financial resources: Budget, Contract, Invoice, Payment, Bonus",
  "type": "object",

  "required": ["id","resourceType","type","profile","status","snomi_version","meta","currency","parties"],

  "properties": {
    "id":            { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "resourceType":  { "type": "string", "const": "Financial" },
    "type":          { "type": "string", "enum": ["Budget","Contract","Invoice","Payment","Bonus"] },
    "profile":       { "type": "string" },
    "status":        { "type": "string", "enum": ["draft","active","completed","archived","cancelled","retired","disputed"] },
    "snomi_version": { "type": "string", "pattern": "^\\d+\\.\\d+(\\.\\d+)?$" },
    "meta": {
      "type": "object",
      "required": ["created_at"],
      "properties": {
        "created_at":  { "type": "string", "format": "date-time" },
        "updated_at":  { "type": "string", "format": "date-time" },
        "produced_by": { "type": "string" },
        "source_url":  { "type": "string", "format": "uri" }
      }
    },
    "campaign": {
      "type": "object",
      "required": ["resourceType","id"],
      "properties": {
        "resourceType": { "type": "string", "const": "Campaign" },
        "id": { "type": "string" }
      }
    },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "parties": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["resourceType","id"],
        "properties": {
          "resourceType": { "type": "string", "const": "Actor" },
          "id": { "type": "string" }
        }
      }
    },

    "total_gross":    { "type": "number" },
    "total_net":      { "type": "number" },
    "agency_fee_pct": { "type": "number", "minimum": 0, "maximum": 100 },
    "tax_rate":       { "type": "number", "minimum": 0, "maximum": 100 },
    "allocations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["amount_net"],
        "properties": {
          "creator":               { "type": "object" },
          "platform":              { "type": "string" },
          "format":                { "type": "string" },
          "posts_count":           { "type": "integer", "minimum": 1 },
          "amount_net":            { "type": "number" },
          "amount_gross":          { "type": "number" },
          "fee_type":              { "type": "string", "enum": ["flat","cpe","cpm","cpa","rev_share","gifting","hybrid"] },
          "usage_rights_included": { "type": "boolean" }
        }
      }
    },

    "signed_at":    { "type": "string", "format": "date" },
    "start_date":   { "type": "string", "format": "date" },
    "end_date":     { "type": "string", "format": "date" },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["profile","quantity"],
        "properties": {
          "profile":   { "type": "string" },
          "quantity":  { "type": "integer", "minimum": 1 },
          "due_date":  { "type": "string", "format": "date" },
          "brief_url": { "type": "string", "format": "uri" },
          "status":    { "type": "string", "enum": ["pending","submitted","approved","rejected","published"] }
        }
      }
    },
    "exclusivity": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category","start_date"],
        "properties": {
          "category":       { "type": "string" },
          "competing_brand":{ "type": "string" },
          "start_date":     { "type": "string", "format": "date" },
          "end_date":       { "type": "string", "format": "date" }
        }
      }
    },
    "usage_rights": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type":             { "type": "string", "enum": ["paid_social","owned","earned","ooh","tv","print","packaging"] },
          "duration_months":  { "type": "integer" },
          "territory":        { "type": "array", "items": { "type": "string", "pattern": "^[A-Z]{2}$" } },
          "fee_additional":   { "type": "object" }
        }
      }
    },
    "payment_terms": {
      "type": "object",
      "required": ["structure"],
      "properties": {
        "structure":        { "type": "string", "enum": ["full_upfront","split_50_50","split_30_70","on_delivery","on_approval","net_30","net_60","milestone"] },
        "upfront_pct":      { "type": "number" },
        "on_delivery_pct":  { "type": "number" },
        "on_approval_pct":  { "type": "number" }
      }
    },
    "governing_law": { "type": "string", "pattern": "^[A-Z]{2}$" },

    "from": { "type": "object" },
    "to":   { "type": "object" },
    "contract": { "type": "object" },
    "issued_at":  { "type": "string", "format": "date" },
    "due_at":     { "type": "string", "format": "date" },
    "paid_at":    { "type": "string", "format": "date" },
    "lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description","quantity","unit_price_net","amount_net"],
        "properties": {
          "description":     { "type": "string" },
          "deliverable_ref": { "type": "string" },
          "quantity":        { "type": "integer" },
          "unit_price_net":  { "type": "object" },
          "amount_net":      { "type": "object" }
        }
      }
    },

    "invoice":        { "type": "object" },
    "amount":         { "type": "object" },
    "transferred_at": { "type": "string", "format": "date-time" },
    "method":         { "type": "string" },
    "reference":      { "type": "string" },

    "creator":         { "type": "object" },
    "trigger_metric":  { "type": "string" },
    "trigger_value":   { "type": "string" },
    "actual_value":    { "type": "string" },
    "earned_at":       { "type": "string", "format": "date" }
  }
}
